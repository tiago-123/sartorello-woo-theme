{
    "name": "sartorello-woo-theme",
    "version": "1.0.0",
    "author": "",
    "description": "",
    "keywords": [],
    "license": "ISC",
    "main": "index.js",
    "type": "module",
    "dependencies": {
        "alpinejs": "^3.15.12",
        "@alpinejs/collapse": "^3.15.12",
        "@alpinejs/intersect": "^3.15.12",
        "@alpinejs/resize": "^3.15.12"
    },
    "devDependencies": {
        "tailwindcss": "^4.3.0",
        "@tailwindcss/cli": "^4.3.0",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3"
    },
    "scripts": {
        "dev": "npm run webpack-dev && npm run tailwind-dev",
        "build": "npm run webpack-build && npm run tailwind-build",
        "webpack-dev": "webpack --mode development --watch; ",
        "webpack-build": "webpack --mode production",
        "tailwind-dev": "npx @tailwindcss/cli -i ./src/input.css -o ./assets/frontend/css/style.css --watch",
        "tailwind-build": "npx @tailwindcss/cli -i ./src/input.css -o ./assets/frontend/css/style.css",
        "upgrade-dependencies": "npx npm-check-updates -u && npm install"
    }
}